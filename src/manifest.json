{
  "manifest_version": 3,
  "name": "Recaptain",
  "version": "0.1.0",
  "description": "Record a browser session (clicks, screenshots, console, network, voice) into one shareable bundle. 100% free, local, and private.",
  "permissions": [
    "tabs",
    "scripting",
    "downloads",
    "offscreen",
    "storage",
    "sidePanel"
  ],
  "optional_host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Recaptain",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["offscreen.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
